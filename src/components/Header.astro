---
import logo_1 from "../assets/logo_1.png";
import logoDetalleEnObra from "../assets/detalle_obra.jpg";
---

<header
    id="main-header"
    class="h-20 md:h-auto shadow-sm fixed w-full z-40 top-0 bg-transparent header-transition"
>
    <!-- Contenedor principal con max-w-5xl para centralizar los elementos -->
    <div
        class="h-20 md:h-auto px-4 py-2 flex w-full items-center justify-between max-w-5xl mx-auto"
    >
        <!-- Logo (Izquierda) -->
        <div
            class="font-extrabold flex items-center justify-start w-20 md:w-25 shrink-0 relative z-50 md:flex-1"
        >
            <a
                id="logo-header"
                data-smooth-scroll
                href="#inicio"
                class="cursor-pointer flex items-center w-[35%] transition-all duration-300 ease-in-out"
            >
                <img
                    src={logoDetalleEnObra.src}
                    alt="Logo"
                    class="w-full h-full object-contain rounded-full"
                />
            </a>
        </div>

        <!-- Botón Menú Hamburguesa (Mobile) -->
        <button
            id="menu-toggle"
            class="md:hidden relative z-50 flex items-center text-gray-100 hover:text-white focus:outline-none transition-colors"
        >
            <svg
                class="w-8 h-8"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                xmlns="http://www.w3.org/2000/svg"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
        </button>

        <!-- Navegación y CTA (Centro y Derecha en Desktop / Dropdown en Mobile) -->
        <div
            id="nav-menu"
            class="fixed md:static top-0 left-0 w-full md:w-auto h-screen md:h-auto bg-white/95 md:bg-transparent backdrop-blur-md md:backdrop-blur-none flex-col md:flex-row items-center justify-center md:justify-end gap-8 md:gap-6 lg:gap-10 -translate-y-full md:translate-y-0 transition-transform duration-300 ease-in-out flex md:flex-[2] z-40 md:z-auto"
        >
            <!-- Nav (Centro) -->
            <nav
                class="flex flex-col md:flex-row items-center gap-8 md:gap-6 lg:gap-10 mt-10 md:mt-0 justify-center"
            >
                <a
                    href="#inicio"
                    data-smooth-scroll
                    class="nav-link text-gray-800 md:text-gray-100 font-bold transition-colors text-2xl md:text-base"
                    >Inicio</a
                >
                <a
                    href="#services"
                    data-smooth-scroll
                    class="nav-link text-gray-800 md:text-gray-100 font-bold transition-colors text-2xl md:text-base"
                    >Servicios</a
                >
                <a
                    href="#projects"
                    data-smooth-scroll
                    class="nav-link text-gray-800 md:text-gray-100 font-bold transition-colors text-2xl md:text-base"
                    >Proyectos</a
                >
                <a
                    href="#contact"
                    class="nav-link text-gray-800 md:text-gray-100 font-bold transition-colors text-2xl md:text-base"
                    >Contacto</a
                >
            </nav>

            <!-- CTA Cotizar (Derecha, levemente tirado a la izquierda con md:ml-4 lg:ml-8) -->
            <div class="flex items-center md:ml-4 lg:ml-8 mt-5 md:mt-0">
                <a
                    href="#cta"
                    data-smooth-scroll
                    target="_blank"
                    rel="noopener noreferrer"
                    class="bg-[#d0a676] hover:bg-[#b18a61] text-white font-bold py-2 px-4 rounded mt-5 md:mt-0 transition-colors duration-300 cursor-pointer inline-flex items-center gap-2"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                    >
                        <path
                            d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"
                        ></path>
                    </svg>
                    <span>Cotizar</span>
                </a>
            </div>
        </div>
    </div>
</header>

<style>
    .header-transition {
        transition:
            background-color 0.3s ease,
            backdrop-filter 0.3s ease;
    }
    :global(.scrolled) {
        background-color: rgba(255, 255, 255, 0.9) !important;
        backdrop-filter: blur(12px) !important;
        -webkit-backdrop-filter: blur(12px) !important;
    }
    :global(.scrolled) .nav-link,
    :global(.scrolled) #menu-toggle {
        color: #1f2937 !important; /* Gris oscuro para mejorar la legibilidad sobre blanco */
    }
    :global(.scrolled) #logo-header {
        width: 20%;
    }
    :global(body.menu-open) {
        overflow: hidden; /* Evita scroll en la web cuando el menú móvil está abierto */
    }
</style>

<script>
    const setupHeader = () => {
        const header = document.getElementById("main-header");
        const menuToggle = document.getElementById("menu-toggle");
        const navMenu = document.getElementById("nav-menu");

        const handleScroll = () => {
            if (window.scrollY > 50) {
                header?.classList.add("scrolled");
                header?.classList.remove("bg-transparent");
            } else {
                header?.classList.remove("scrolled");
                header?.classList.add("bg-transparent");
            }
        };

        const toggleMenu = () => {
            const isClosed = navMenu?.classList.contains("-translate-y-full");
            if (isClosed) {
                // Abrir menú
                navMenu?.classList.remove("-translate-y-full");
                navMenu?.classList.add("translate-y-0");
                document.body.classList.add("menu-open");
                // Al abrir forzamos clases como si hubiera scroll para que se vea el fondo blanco y letras oscuras (si el header no está ya con bg)
                header?.classList.add("scrolled");
            } else {
                // Cerrar menú
                navMenu?.classList.remove("translate-y-0");
                navMenu?.classList.add("-translate-y-full");
                document.body.classList.remove("menu-open");
                // Restaurar en base a scroll real
                handleScroll();
            }
        };

        window.addEventListener("scroll", handleScroll);
        menuToggle?.addEventListener("click", toggleMenu);

        handleScroll();
    };

    setupHeader();
</script>
