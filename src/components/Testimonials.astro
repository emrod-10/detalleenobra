---
import reseña1 from "../assets/images/reseña_1.jpg";
import reseña2 from "../assets/images/reseña_2.jpg";
import reseña3 from "../assets/images/reseña_3.jpg";

const testimonials = [
  {
    text: "Firma de consultoría de diseño interior que aporta sensibilidad al diseño, los mejores restaurantes, hoteles, oficinas y viviendas de todo el mundo. Representamos calidad, seguridad y credibilidad, así que puedes estar seguro de nuestro trabajo. Inicialmente",
    name: "Sultana león",
    role: "Asociado con co-gerentes",
    image: reseña1.src
  },
  {
    text: "Firma de consultoría de diseño interior que aporta sensibilidad al diseño, los mejores restaurantes, hoteles, oficinas y viviendas de todo el mundo. Representamos calidad, seguridad y credibilidad, así que puedes estar seguro de nuestro trabajo. Inicialmente",
    name: "John Doe",
    role: "Director General",
    image: reseña2.src
  },
  {
    text: "Firma de consultoría de diseño interior que aporta sensibilidad al diseño, los mejores restaurantes, hoteles, oficinas y viviendas de todo el mundo. Representamos calidad, seguridad y credibilidad, así que puedes estar seguro de nuestro trabajo. Inicialmente",
    name: "Carola Thompson",
    role: "Directora Creativa",
    image: reseña3.src
  },
  {
    text: "Firma de consultoría de diseño interior que aporta sensibilidad al diseño, los mejores restaurantes, hoteles, oficinas y viviendas de todo el mundo. Representamos calidad, seguridad y credibilidad, así que puedes estar seguro de nuestro trabajo. Inicialmente",
    name: "Carlos Mendoza",
    role: "Arquitecto Senior",
    image: reseña2.src
  }
];
---




<section class="py-20 bg-white overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div x-data="{
        scrollNext() { 
            const slider = this.$refs.slider;
            slider.scrollBy({ left: slider.offsetWidth / 1.2, behavior: 'smooth' });
        },
        scrollPrev() { 
            const slider = this.$refs.slider;
            slider.scrollBy({ left: -(slider.offsetWidth / 1.2), behavior: 'smooth' });
        }
    }">
      
      <!-- Header -->
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-16">
        <div>
          <p class="text-sm font-medium tracking-wider text-gray-500 uppercase mb-3">Nuestros testimonios</p>
          <h2 class="text-3xl md:text-5xl font-bold text-gray-900">Lo que dicen nuestros clientes</h2>
        </div>
        
        <!-- Navigation Arrows -->
        <div class="flex gap-4">
          <button 
            @click="scrollPrev" 
            class="hover:cursor-pointer  md:w-14 w-10 md:h-14 h-10 rounded-full bg-[#1c1c1c] text-white flex items-center justify-center hover:bg-black transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-900"
            aria-label="Anterior testimonio"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
          </button>
          <button 
            @click="scrollNext" 
            class="hover:cursor-pointer md:w-14 w-10 md:h-14 h-10 rounded-full bg-[#d2a373] text-white flex items-center justify-center hover:bg-[#c29362] transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#d2a373]"
            aria-label="Siguiente testimonio"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </button>
        </div>
      </div>

      <!-- Slider Container -->
      <div 
        x-ref="slider" 
        class="flex overflow-x-auto snap-x snap-mandatory gap-8 pb-12 -mx-2 md:-mx-4 px-2 sm:mx-0 sm:px-0 [&::-webkit-scrollbar]:hidden [-ms-overflow-style:none] [scrollbar-width:none]"
      >
        {testimonials.map((t) => (
          <div class="snap-start w-full sm:w-[calc(50%-16px)] lg:w-[calc(33.333%-21.33px)] shrink-0 flex flex-col gap-8">
            
            <!-- Card -->
            <div class="bg-white border border-gray-100 p-8 sm:p-10 relative shadow-sm">
              <!-- Stars -->
              <div class="flex gap-1.5 mb-6">
                {[1, 2, 3, 4, 5].map(() => (
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-[#d2a373]" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
              
              <!-- Text -->
              <p class="text-gray-600 text-base leading-relaxed">
                {t.text}
              </p>
              
              <!-- Triangle pointing down -->
              <div class="absolute -bottom-3 left-12 w-6 h-6 bg-white border-b border-r border-gray-100 transform rotate-45 shadow-[2px_2px_2px_rgba(0,0,0,0.02)]"></div>
            </div>
            
            <!-- User Info -->
            <div class="flex items-center gap-5 px-4">
              <img src={t.image} alt={t.name} class="w-16 h-16 object-cover" />
              <div>
                <p class="text-sm text-gray-500 mb-0.5">{t.role}</p>
                <p class="text-lg font-bold text-gray-900">{t.name}</p>
              </div>
            </div>
            
          </div>
        ))}
      </div>

    </div>
  </div>
</section>
