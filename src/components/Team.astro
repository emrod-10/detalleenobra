---
import team1 from "../assets/images/team_1.png";
import team2 from "../assets/images/team_2.png";
import team3 from "../assets/images/team_3.png";
---

<section
    id="team"
    class="h-screen w-full mx-auto bg-[#f5f5f5] mt-15 flex flex-col gap-10 justify-center"
>
    <div class="flex flex-col items-center justify-center gap-2">
        <span class="text-[#b18a61] font-bold text-lg uppercase"
            >Conoce a profesionales</span
        >
        <h2 class="text-4xl font-bold">Miembros de nuestro equipo</h2>
    </div>
    <div class="flex items-center justify-center w-[80%] mx-auto gap-5">
        <div
            class="flex flex-col justify-center items-center p-2 w-full bg-white shadow-md"
        >
            <img src={team1.src} alt="foto-perfil-1" />
            <div class="flex flex-col items-center justify-center w-full">
                <h2 class="text-lg font-bold">Mariana Morales</h2>
                <p class="text-sm text-gray-500">Arquitecta</p>
            </div>
        </div>
        <div
            class="flex flex-col justify-center items-center p-2 w-full bg-white shadow-md"
        >
            <img src={team2.src} alt="foto-perfil-2" />
            <div class="flex flex-col items-center justify-center w-full">
                <h2 class="text-lg font-bold">Mariana Morales</h2>
                <p class="text-sm text-gray-500">Arquitecta</p>
            </div>
        </div>
        <div
            class="flex flex-col justify-center items-center p-2 w-full bg-white shadow-md"
        >
            <img src={team1.src} alt="foto-perfil-3" />
            <div class="flex flex-col items-center justify-center w-full">
                <h2 class="text-lg font-bold">Mariana Morales</h2>
                <p class="text-sm text-gray-500">Arquitecta</p>
            </div>
        </div>
    </div>
</section>
