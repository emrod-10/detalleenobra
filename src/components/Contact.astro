---
---

<section class="py-20 bg-white" id="contacto">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
            <h2 class="text-3xl font-extrabold text-gray-900 sm:text-4xl">Contacto</h2>
            <p class="mt-4 text-lg text-gray-500">
                Estamos aquí para ayudarte. Escríbenos y te responderemos a la brevedad.
            </p>
        </div>
        <div 
            class="bg-gray-50 rounded-2xl shadow-xl overflow-hidden p-8 border border-gray-100"
            x-data="contactForm()"
        >
            <form @submit.prevent="submitForm" class="space-y-6">
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                    <div>
                        <label for="nombre" class="block text-sm font-medium text-gray-700">Nombre</label>
                        <input type="text" id="nombre" x-model="formData.nombre" required class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-[#d0a676] focus:ring-[#d0a676] sm:text-sm p-3 border outline-none transition-colors" placeholder="Tu nombre">
                    </div>
                    <div>
                        <label for="apellido" class="block text-sm font-medium text-gray-700">Apellido</label>
                        <input type="text" id="apellido" x-model="formData.apellido" required class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-[#d0a676] focus:ring-[#d0a676] sm:text-sm p-3 border outline-none transition-colors" placeholder="Tu apellido">
                    </div>
                </div>
                
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                    <div>
                        <label for="telefono" class="block text-sm font-medium text-gray-700">Teléfono</label>
                        <input type="tel" id="telefono" x-model="formData.telefono" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-[#d0a676] focus:ring-[#d0a676] sm:text-sm p-3 border outline-none transition-colors" placeholder="Tu número de teléfono">
                    </div>
                    <div>
                        <label for="email" class="block text-sm font-medium text-gray-700">Mail</label>
                        <input type="email" id="email" x-model="formData.email" required class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-[#d0a676] focus:ring-[#d0a676] sm:text-sm p-3 border outline-none transition-colors" placeholder="tu@email.com">
                    </div>
                </div>

                <div>
                    <label for="mensaje" class="block text-sm font-medium text-gray-700">Mensaje</label>
                    <textarea id="mensaje" rows="4" x-model="formData.mensaje" required class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-[#d0a676] focus:ring-[#d0a676] sm:text-sm p-3 border resize-none outline-none transition-colors" placeholder="¿En qué te podemos ayudar?"></textarea>
                </div>

                <div class="flex justify-end pt-2">
                    <button 
                        type="submit" 
                        class="inline-flex justify-center items-center py-3 px-8 border border-transparent shadow-sm text-base font-bold rounded-md text-white bg-[#d0a676] hover:bg-[#b18a61] focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#d0a676] transition-colors duration-300 w-full sm:w-auto cursor-pointer"
                        :disabled="status === 'loading'"
                        :class="status === 'loading' ? 'opacity-75 cursor-not-allowed' : ''"
                    >
                        <span x-show="status !== 'loading'">Enviar mensaje</span>
                        <span x-show="status === 'loading'" style="display: none;" class="flex items-center gap-2">
                            <svg class="animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                            </svg>
                            Enviando...
                        </span>
                    </button>
                </div>
                
                <div x-show="status === 'success'" style="display: none;" class="mt-4 p-4 rounded-md bg-green-50 border border-green-200" x-transition>
                    <p class="text-sm text-green-700 font-medium text-center">¡Gracias por contactarnos! Tu mensaje ha sido enviado correctamente.</p>
                </div>
                
                <div x-show="status === 'error'" style="display: none;" class="mt-4 p-4 rounded-md bg-red-50 border border-red-200" x-transition>
                    <p class="text-sm text-red-700 font-medium text-center">Hubo un error al enviar el mensaje. Por favor, intenta nuevamente.</p>
                </div>
            </form>
        </div>
    </div>
</section>

<script is:inline>
    document.addEventListener('alpine:init', () => {
        Alpine.data('contactForm', () => ({
            formData: {
                nombre: '',
                apellido: '',
                telefono: '',
                email: '',
                mensaje: ''
            },
            status: 'idle', // 'idle', 'loading', 'success', 'error'
            async submitForm() {
                this.status = 'loading';
                try {
                    // Ejemplo de URL (JSONPlaceholder), reemplazar en prod
                    const response = await fetch('https://jsonplaceholder.typicode.com/posts', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        body: JSON.stringify(this.formData),
                    });
                    
                    if (response.ok) {
                        this.status = 'success';
                        this.formData = {
                            nombre: '',
                            apellido: '',
                            telefono: '',
                            email: '',
                            mensaje: ''
                        };
                        setTimeout(() => {
                            if(this.status === 'success') this.status = 'idle';
                        }, 5000);
                    } else {
                        this.status = 'error';
                        setTimeout(() => {
                            if(this.status === 'error') this.status = 'idle';
                        }, 5000);
                    }
                } catch (error) {
                    this.status = 'error';
                    setTimeout(() => {
                        if(this.status === 'error') this.status = 'idle';
                    }, 5000);
                }
            }
        }));
    });
</script>
