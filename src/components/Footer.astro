---
import logoDetalleEnObra from "../assets/detalle_obra.jpg";
---

<footer class="bg-[#1a1a1a] text-white py-12 md:py-16 mt-auto">
    <div
        class="max-w-5xl mx-auto px-4 grid grid-cols-1 md:grid-cols-3 gap-8 items-center md:items-start text-center md:text-left"
    >
        <!-- Logo y descripción -->
        <div class="flex flex-col items-center md:items-start gap-4">
            <a
                href="#inicio"
                data-smooth-scroll
                class="w-24 md:w-32 bg-white rounded-full overflow-hidden inline-block transition-transform hover:scale-105"
            >
                <img
                    src={logoDetalleEnObra.src}
                    alt="Logo Detalle en Obra"
                    class="w-full h-full object-contain"
                />
            </a>
            <p class="text-gray-400 text-sm mt-2">
                Construyendo tus sueños con el máximo detalle y profesionalismo.
            </p>
        </div>

        <!-- Navegación Rápida -->
        <div class="flex flex-col items-center md:items-start gap-3">
            <h3 class="text-lg font-bold text-[#d0a676] mb-2">Navegación</h3>
            <a
                href="#inicio"
                class="text-gray-300 hover:text-[#d0a676] transition-colors"
                data-smooth-scroll>Inicio</a
            >
            <a
                href="#services"
                class="text-gray-300 hover:text-[#d0a676] transition-colors"
                data-smooth-scroll>Servicios</a
            >
            <a
                href="#projects"
                class="text-gray-300 hover:text-[#d0a676] transition-colors"
                data-smooth-scroll>Proyectos</a
            >
            <a
                href="#contact"
                class="text-gray-300 hover:text-[#d0a676] transition-colors"
                data-smooth-scroll>Contacto</a
            >
        </div>

        <!-- Redes Sociales -->
        <div class="flex flex-col items-center md:items-start gap-3">
            <h3 class="text-lg font-bold text-[#d0a676] mb-2">Síguenos</h3>
            <div class="flex gap-4">
                <a
                    href="#"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="w-10 h-10 rounded-full bg-[#2a2a2a] flex items-center justify-center text-gray-300 hover:bg-[#d0a676] hover:text-white transition-all duration-300"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        ><path
                            d="M12 2.04c-5.5 0-10 4.49-10 10.02 0 5 3.66 9.15 8.44 9.9v-7H7.9v-2.9h2.54V9.85c0-2.51 1.49-3.89 3.78-3.89 1.09 0 2.23.19 2.23.19v2.47h-1.26c-1.24 0-1.63.77-1.63 1.56v1.88h2.78l-.45 2.9h-2.33v7a10 10 0 0 0 8.44-9.9c0-5.53-4.5-10.02-10-10.02z"
                        ></path></svg
                    >
                </a>
                <a
                    href="#"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="w-10 h-10 rounded-full bg-[#2a2a2a] flex items-center justify-center text-gray-300 hover:bg-[#d0a676] hover:text-white transition-all duration-300"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        ><path
                            d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"
                        ></path></svg
                    >
                </a>
            </div>
        </div>
    </div>

    <!-- Línea divisoria y Copyright -->
    <div
        class="max-w-5xl mx-auto px-4 mt-12 pt-8 border-t border-[#333] text-center text-sm text-gray-500"
    >
        &copy; {new Date().getFullYear()} Detalle en Obra. Todos los derechos reservados.
    </div>
</footer>
